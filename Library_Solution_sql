CREATE TABLE Overdue_member_report AS (
SELECT
	i.issued_member_id,
    SUM(DATEDIFF(CURRENT_DATE(),i.issued_date) - 30 ) AS overdue_days,
    COUNT(*) AS total_book_issued_with_overdue,
    ROUND(SUM(DATEDIFF(CURRENT_DATE(),i.issued_date) - 30) * 0.5,2) AS total_due_based_on_books_members,
    (SELECT 
		COUNT(*) 
    FROM issued_status isb
    WHERE isb.issued_member_id = i.issued_member_id) 
    AS Total_book_issued
FROM issued_status i 
LEFT JOIN returned_status r
ON i.issued_id = r.issued_id
WHERE r.issued_id IS NULL 
AND i.issued_date <= CURRENT_DATE() - INTERVAL 30 DAY
