ON i.issued_id = r.issued_id
LEFT JOIN members m
on m.member_id = i.issued_member_id
LEFT JOIN books b
ON b.isbn = i.issued_book_isbn
WHERE r.return_date is null 
and DATEDIFF(current_date(),i.issued_date) > 30;


