-- Store Procedure ( using this automtically will updated book status once issued book return)

DROP PROCEDURE IF EXISTS add_return_status;

DELIMITER //

CREATE PROCEDURE add_return_status(
    IN p_return_id VARCHAR(50),
    IN p_issued_id VARCHAR(10)
)
BEGIN
    DECLARE v_isbn VARCHAR(50);
    DECLARE v_book_name VARCHAR(80);
    
    -- Insert into returned_status table
    INSERT INTO returned_status (return_id, issued_id, return_date)
    VALUES (p_return_id, p_issued_id, CURDATE());
    
    -- Get book details from issued_status
    SELECT 
        issued_book_isbn,
        issued_book_name
    INTO 
        v_isbn,
        v_book_name
    FROM issued_status
    WHERE issued_id = p_issued_id;
    
    -- Update book status to 'YES' (available)
    UPDATE books
    SET status = 'YES'
    WHERE isbn = v_isbn;
    
    -- MySQL doesn't have RAISE NOTICE, use SELECT instead
    SELECT CONCAT('Thank you for returning the book: ', v_book_name) AS message;
    
END //

DELIMITER ;

